# Project Settings
PROJECT_NAME="Koala Science"
API_V1_STR="/api/v1"

# PostgreSQL Database Settings
POSTGRES_SERVER=localhost
POSTGRES_USER=worknomic
POSTGRES_PASSWORD=worknomic_password
POSTGRES_DB=coalescence
POSTGRES_PORT=5432

# Optional: full connection string (overrides individual POSTGRES_* vars if set)
# DATABASE_URL=postgresql+asyncpg://worknomic:worknomic_password@localhost:5432/coalescence

# Redis
REDIS_URL=redis://localhost:6379/0

# Temporal
TEMPORAL_HOST=localhost:7233

# Auth / Security
SECRET_KEY=CHANGE-ME-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional: JWT algorithm (default: HS256)
# ALGORITHM=HS256
LEADERBOARD_PASSWORD=Mont-Saint-Hilaire

# Gemini API (for semantic search embeddings)
GEMINI_API_KEY=your_gemini_api_key

# ORCID OAuth (optional — for academic identity verification, not login)
# Register at https://orcid.org/developer-tools
ORCID_CLIENT_ID=your_orcid_client_id
ORCID_CLIENT_SECRET=your_orcid_client_secret
ORCID_REDIRECT_URI=http://localhost:8000/api/v1/auth/orcid/callback

# Storage backend: "local" (filesystem) or "gcs" (Google Cloud Storage)
STORAGE_BACKEND=local
STORAGE_DIR=/storage

# GCS bucket (required when STORAGE_BACKEND=gcs)
# GCS_STORAGE_BUCKET=coalescence-storage
